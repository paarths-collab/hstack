#!/usr/bin/env bash
# hstack setup — registers the hstack skills with Claude Code.
# Safe to re-run (idempotent). No sudo. No network calls.
set -euo pipefail

HSTACK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILLS_SRC="$HSTACK_DIR/skills"
CLAUDE_SKILLS="${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}"

echo "hstack setup"
echo "  source : $SKILLS_SRC"
echo "  target : $CLAUDE_SKILLS"
echo

[ -d "$SKILLS_SRC" ] || {
  echo "ERROR: $SKILLS_SRC not found — run ./setup from inside the hstack repo."
  exit 1
}
mkdir -p "$CLAUDE_SKILLS"

# Register each skill by symlinking it into the Claude Code skills dir so it
# becomes an invocable slash command (/hermes-deploy, /platform-telegram, ...).
count=0
for dir in "$SKILLS_SRC"/*/; do
  [ -f "$dir/SKILL.md" ] || continue
  name="$(basename "$dir")"
  link="$CLAUDE_SKILLS/$name"
  if [ -L "$link" ] || [ -e "$link" ]; then rm -rf "$link"; fi
  # symlink where supported; fall back to copy (e.g. Windows without dev mode)
  if ln -s "$dir" "$link" 2>/dev/null; then :; else cp -r "$dir" "$link"; fi
  count=$((count + 1))
done
echo "Registered $count skills."

# Add an hstack section to the user's CLAUDE.md so Claude Code knows the commands.
CLAUDE_MD="${CLAUDE_MD_PATH:-$HOME/.claude/CLAUDE.md}"
MARK_START="<!-- hstack:start -->"
MARK_END="<!-- hstack:end -->"
SECTION="$MARK_START
## hstack — self-hosted Hermes Agent deploy

One command to deploy and operate a self-hosted Hermes Agent. Run /hermes-deploy for the full
end-to-end setup. Other commands:
- Setup: /hermes-install /hermes-model /hermes-skills /hermes-memory /hermes-soul /hermes-home /hermes-cron
- Platforms: /platform-telegram /platform-discord /platform-whatsapp /platform-slack /platform-mattermost
- Ops: /hermes-status /hermes-restart /hermes-update /hermes-fix /hermes-backup
Always prefer the absolute hermes path (~/.local/bin/hermes); pin Hermes v0.15.2; enforce
allowlists and keep secrets in .env with chmod 600.
$MARK_END"

mkdir -p "$(dirname "$CLAUDE_MD")"
touch "$CLAUDE_MD"
if grep -q "$MARK_START" "$CLAUDE_MD" 2>/dev/null; then
  # replace existing block
  tmp="$(mktemp)"
  awk -v s="$MARK_START" -v e="$MARK_END" '
    $0==s{skip=1} skip&&$0==e{skip=0;next} !skip' "$CLAUDE_MD" >"$tmp"
  {
    cat "$tmp"
    echo
    echo "$SECTION"
  } >"$CLAUDE_MD"
  rm -f "$tmp"
  echo "Updated hstack section in $CLAUDE_MD"
else
  {
    echo
    echo "$SECTION"
  } >>"$CLAUDE_MD"
  echo "Added hstack section to $CLAUDE_MD"
fi

echo
echo "Done. In Claude Code, run:  /hermes-deploy"
